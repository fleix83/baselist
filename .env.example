# Neon Postgres (Pooler-URL aus dem Neon-Dashboard)
DATABASE_URL=

# Neon Auth (Werte gemäss aktueller Neon-Auth-Doku / Provisionierung)
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Eventfrog Public API
EVENTFROG_API_KEY=

# Infomaniak AI Tools (Auto-Moderation)
INFOMANIAK_API_TOKEN=
INFOMANIAK_PRODUCT_ID=
INFOMANIAK_MODEL=mistralai/Mistral-Small-4-119B-2603   # exakte Modell-ID aus dem Infomaniak-Katalog

# Cloudflare R2 (Bildspeicher, S3-kompatibel)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=baselist-media
R2_PUBLIC_URL=

# Absicherung der Cron-Route /api/cron/import
CRON_SECRET=

# Öffentliche Basis-URL der App (für OG-Tags, Links)
PUBLIC_BASE_URL=http://localhost:3000

# Admins (kommagetrennte E-Mail-Liste; greift beim Onboarding)
ADMIN_EMAILS=

# Zusätzliche Sperrwörter (kommagetrennt, ergänzt die Liste im Code)
BLOCKWORDS=
