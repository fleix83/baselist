# Neon Postgres (Pooler-URL aus dem Neon-Dashboard)
DATABASE_URL=

# Neon Auth (Werte gemäss aktueller Neon-Auth-Doku / Provisionierung)
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Eventfrog Public API
EVENTFROG_API_KEY=

# Infomaniak AI Tools (Auto-Moderation)
INFOMANIAK_API_TOKEN=
INFOMANIAK_PRODUCT_ID=
INFOMANIAK_MODEL=mistral-small-4

# Cloudflare R2 (Bildspeicher, S3-kompatibel)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=baselist-media
R2_PUBLIC_URL=

# Absicherung der Cron-Route /api/cron/import
CRON_SECRET=

# Öffentliche Basis-URL der App (für OG-Tags, Links)
PUBLIC_BASE_URL=http://localhost:3000
